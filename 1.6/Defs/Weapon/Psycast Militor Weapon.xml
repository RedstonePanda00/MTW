    <destroyOnDrop>true</destroyOnDrop>
    <relicChance>0</relicChance>
    <graphicData>
      <texPath>Things/PsyCast_SMG</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.75</drawSize>
    </graphicData>
    <soundInteract>Interact_SMG</soundInteract>
    <weaponClasses>
