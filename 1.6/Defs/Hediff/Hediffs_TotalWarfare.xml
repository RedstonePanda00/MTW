  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_TacticalArtilleryCoordinationModule_AutoMortar</defName>
    <label>Tactical Coordination Module: Mortar Support</label>
    <description>Summons mortar support for combat assistance when player units are detected within a 150-tile radius.</description>
	<comps>
      <li Class="NCL.HediffCompProperties_TurretCallerAutoMortar">
        <turretDef>Turret_TW_AutoMortar</turretDef>
        <turretCount>1</turretCount>
        <spawnRadius>20</spawnRadius>
        <minSpawnDistance>8</minSpawnDistance>
        <leaveSlag>false</leaveSlag>
        <canRoofPunch>true</canRoofPunch> 
        <triggerRadius>150</triggerRadius> 

      </li>
    </comps>
    <stages>
      
    </stages>
  </HediffDef>

    
