    <ThinkTreeDef>
        <defName>NCL_Dinergate_Drone_thinkTreeMain</defName>
        <thinkRoot Class="ThinkNode_Priority">
            <subNodes>
                <li Class="ThinkNode_Subtree">
                    <treeDef>Downed</treeDef>
                </li>
                <li Class="ThinkNode_QueuedJob" />
                <li Class="ThinkNode_Subtree">
                    <treeDef>LordDuty</treeDef>
                </li>

                <li Class="NyarsModPackOne.JobGiver_AIFightEnemiesInPlace">
                    <targetAcquireRadius>1</targetAcquireRadius>
                    <targetKeepRadius>40</targetKeepRadius>
                </li>
                <li Class="NyarsModPackOne.JobGiver_FollowTarget" />

                <li Class="ThinkNode_Tagger">
                    <tagToGive>Idle</tagToGive>
                    <subNodes>
                        <li Class="JobGiver_Idle">
                            <ticks>30</ticks>
                        </li>
                    </subNodes>
                </li>
                <li Class="JobGiver_IdleError" />
            </subNodes>
        </thinkRoot>
    </ThinkTreeDef>

