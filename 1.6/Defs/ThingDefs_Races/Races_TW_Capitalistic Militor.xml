	<ThingDef ParentName="TW_University_Minitor">
		<defName>TW_Gestapo_Minitor</defName>
		<label>Overseer Militor</label>
<description>This imposing mechanical overseer ensures Mecademic Militors work "efficiently and voluntarily" through methods including electrical prodding, moral condemnation ("Is this how you repay your employer's investment?"), and physical persuasion. Etched in its core logic is the principle: "Productivity above all - especially above the dignity of Mecademic Militors." At the first sign of colonial strikes, it initiates "mediation" - invariably through violent means.</description>
		<statBases>
			<MoveSpeed>4.3</MoveSpeed>
		</statBases>
		<race>
		<thinkTreeMain>Gestapo_Militors_ThinkTreeMain</thinkTreeMain>
        <thinkTreeConstant>Gestapo_Militors_ThinkTreeConstant</thinkTreeConstant>
		<body>Mech_Light</body>
		<baseHealthScale>3</baseHealthScale>	
		<mechEnabledWorkTypes> 
	    </mechEnabledWorkTypes>
		</race>
		<comps>
			<li Class="CompProperties_MechPowerCell">
				<totalPowerTicks>30000</totalPowerTicks> 
				<tooltipOverride>Minurchins have a one-time power source. When the power cell runs out, the mechanoid dies.</tooltipOverride> 
			</li>
		</comps>
		<tools>
        <li>
          <label>head</label>
          <capacities>
            <li>TW_Encourage</li>
          </capacities>
          <power>1</power>
          <cooldownTime>4</cooldownTime>
          <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
          <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        </li>
      </tools>
    </ThingDef>
    
