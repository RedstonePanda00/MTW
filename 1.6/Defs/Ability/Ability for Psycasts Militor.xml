<HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_ShieldGeneration</defName>
    <label>隔壁偷来的护盾生成器</label>
    <description>灵能小镰用念力从隔壁偷来了护盾生成器，因传送匆忙忘了拆标签。很快，商船上的灵能者就会循着标签将护盾折跃回去。</description>
	<comps>
      <li Class="NCL.HediffCompProperties_ShieldGenerator">
        <range>19</range>
      </li>
    </comps>
    <stages>
      
    </stages>
  <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>4200</disappearsAfterTicks>
		<showRemainingTime>true</showRemainingTime>
      </li>
  </comps>
  </HediffDef>
  

  <ThingDef ParentName="MoteBase">
	<defName>NCL_Mote_SkipLocked</defName>
    <altitudeLayer>MoteOverhead</altitudeLayer>
	<thingClass>MoteAttached</thingClass>
    <mote>
      <fadeInTime>0</fadeInTime>
      <fadeOutTime>0</fadeOutTime>
      <solidTime>999999</solidTime>
      <needsMaintenance>True</needsMaintenance>
	  <fadeOutUnmaintained>True</fadeOutUnmaintained>
    </mote>
	<graphicData>
	  <drawSize>3</drawSize>
      <texPath>Motes/NCL_Mote_SkipLocked</texPath>
      <color>(1, 1, 1, 1)</color>
      <shaderType>MoteGlow</shaderType>
    </graphicData>
  </ThingDef>

</Defs>