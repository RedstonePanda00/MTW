  <HediffDef>
    <defName>WormPressure</defName>
    <label>WormPressure</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>"Worm's oppressive aura induces fragility and heightened aggression."</description>
    <everCurableByItem>false</everCurableByItem>
    <stages>
      <li>
        <statOffsets>
          <IncomingDamageFactor>1</IncomingDamageFactor>
