<?xml version='1.0' encoding='utf-8'?>
<Defs>
  
    <AbilityDef>
		<defName>Codex_SMG</defName>
		<label>Combat Chronicles: Submachine Gun</label>
		<description>Switch to heavy submachine gun</description>
		<iconPath>Weapons/Codex_SMG</iconPath>
		<jobDef>CastAbilityOnThing</jobDef>
		<aiCanUse>true</aiCanUse>
		<cooldownTicksRange>300</cooldownTicksRange>
		<cooldownPerCharge>true</cooldownPerCharge>
        <targetRequired>false</targetRequired>
		<canUseAoeToGetTargets>false</canUseAoeToGetTargets>
		<stunTargetWhileCasting>true</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
        <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
        <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<verbProperties>
			<defaultCooldownTime>0</defaultCooldownTime>
			<verbClass>Verb_CastAbility</verbClass>
			<onlyManualCast>true</onlyManualCast>
			<range>-1</range>
			<warmupTime>0</warmupTime>
			<soundCast>Interact_SMG</soundCast>
		    <drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
			<targetParams>
                <canTargetSelf>true</canTargetSelf>
                <canTargetMechs>false</canTargetMechs>
                <canTargetPawns>false</canTargetPawns>
                <canTargetBuildings>false</canTargetBuildings>
                <canTargetPlants>false</canTargetPlants>
			</targetParams>
		</verbProperties>
		<comps>
		<li Class="Edited_BM_WeaponSummon.CompProperties_SummonWeapon">
				<weapon>Centurion_Arsenal_Codex_SMG</weapon>
			</li>
			<li Class="CompProperties_AbilityFleckOnTarget">
                <fleckDef>PsycastPsychicEffect</fleckDef>
            </li>
		</comps>
	</AbilityDef>
	
