    <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_LongRangeBallisticsOptimizationSystem</defName>
    <label>Long-Range Ballistics Optimization Module</label>
    <description>This unit's weapon range is increased by 20%.</description>
	<comps>
        
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
      <ShootingAccuracyPawn>1.25</ShootingAccuracyPawn>
			<VEF_VerbRangeFactor>1.25</VEF_VerbRangeFactor>
			<RangedCooldownFactor>0.8</RangedCooldownFactor>
			<IncomingDamageFactor>0.9</IncomingDamageFactor>
			<AimingDelayFactor>0.8</AimingDelayFactor>		  
        </statFactors>
		<statOffsets>
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
    </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
    <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_HighMobilityPhaseShiftDrive_R</defName>
    <label>High-Output Phase Shift Drive</label>
    <description>This unit's movement speed is significantly boosted.</description>
  <comps>
  </comps>
