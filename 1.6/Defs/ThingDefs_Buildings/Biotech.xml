<?xml version='1.0' encoding='utf-8'?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>NCL_MechNode</defName>
    <label>Chainwave Relay</label>
    <description>A quantum communication node co-developed by NCL engineers and mechanitors. Provides 20 base bandwidth units initially, with signal amplification achievable through additional power consumption. Requires dedicated mechanitor bonding as service terminal for stable operation.</description>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <canOverlapZones>false</canOverlapZones>
    <drawerType>MapMeshAndRealTime</drawerType>
    <fillPercent>0.4</fillPercent>
    <graphicData>
      <texPath>Buildings/NCLBandNode</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(6,6)</drawSize>
      <shadowData>
        <volume>(1.5, 0.35, 1.2)</volume>
        <offset>(0, 0, -0.15)</offset>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <buildingTags>
        <li>Biotech</li>
      </buildingTags>
    </building>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <designationCategory>Biotech</designationCategory>
    <uiOrder>2440</uiOrder>
    <statBases>
      <MaxHitPoints>550</MaxHitPoints>
      <WorkToBuild>8000</WorkToBuild>
      <Mass>100</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(4,4)</size>
    <costList>
      <Steel>450</Steel>
	  <Plasteel>350</Plasteel>
      <ComponentIndustrial>16</ComponentIndustrial>
	  <ComponentSpacer>8</ComponentSpacer>
    </costList>
    <researchPrerequisites>
      <li>NCL_MechNode</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>6000</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable" />
    <li Class="NCL.CompProperties_UpgradableBandNode">
      <baseBandwidth>20</baseBandwidth>
      <bandwidthPerGeneration>5</bandwidthPerGeneration>
      <maxGenerations>100</maxGenerations>
      <generationCooldownDays>0</generationCooldownDays>
      <hediff>NCL_MechNode</hediff>
      <tuneSeconds>5</tuneSeconds>
      <retuneDays>1.0</retuneDays>
      <extraPowerConsumptionPerGeneration>2000</extraPowerConsumptionPerGeneration>
    </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_BandNode</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
  </ThingDef>
  
  	<HediffDef>
		<defName>NCL_MechNode</defName>
		<hediffClass>NCL.Hediff_MechNode</hediffClass>
		<label>Chainwave Relay</label>
		<description>A quantum communication node co-developed by NCL engineers and mechanitors. Provides 20 base bandwidth units initially, with signal amplification achievable through additional power consumption. Requires dedicated mechanitor bonding as service terminal for stable operation.</description>
		<isBad>false</isBad>
	</HediffDef>

</Defs>