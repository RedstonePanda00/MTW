	<ThingDef>
    <defName>ShellBreakSpawner</defName>
    <label>Carapace Fracture Spawner</label>
    <description>Subterranean entity emergence detected at this location</description>
    <thingClass>RimWorld.BuildingPawnSpawner</thingClass>
    <size>(1, 1)</size>
    <building Class="RimWorld.BuildingProperties_PawnSpawner">
        
        <groundSpawnerThingToSpawn>TW_Mech_Shell_Fortification_ShellBreakFormed</groundSpawnerThingToSpawn>
        <pawnKindToSpawn>TW_Mech_Shell_Fortification_ShellBreakFormed_Kind</pawnKindToSpawn>
        <defaultFaction>Mechanoid</defaultFaction>
        
        
        <groundSpawnerSpawnDelay>1000~1500</groundSpawnerSpawnDelay>
        <groundSpawnerDestroyAdjacent>true</groundSpawnerDestroyAdjacent>
        <groundSpawnerLetterLabel>Pit gate opened</groundSpawnerLetterLabel>
        
        
        <groundSpawnerSustainedEffecter>EmergencePointSustained8X8</groundSpawnerSustainedEffecter>
        <groundSpawnerCompleteEffecter>EmergencePointComplete8X8</groundSpawnerCompleteEffecter>
    </building>
	
    <destroyable>false</destroyable>
    <holdsRoof>true</holdsRoof>
    <selectable>true</selectable>
    <tickerType>Normal</tickerType>
    <useHitPoints>false</useHitPoints>
    <drawerType>RealtimeOnly</drawerType>
    <uiIconPath>Ability/ReleaseFromBuilding</uiIconPath>
</ThingDef>


   <ThingDef ParentName="BaseWeaponTurret">
    <defName>Shell_FortConstruct_Barrage</defName>
    <label>Conch Shell Artillery System</label>
    <graphicData>
      <texPath>Things/None</texPath>
    </graphicData>
    <uiIconScale>1.25</uiIconScale>
    <weaponTags>
      <li>Shell_FortConstruct_Barrage</li>
    </weaponTags>
    <verbs>
      <li>
	    <verbClass>Verb_Shoot</verbClass>
	    <ai_RangedAlawaysShootGroundBelowTarget>true</ai_RangedAlawaysShootGroundBelowTarget>
		<defaultProjectile>TW_Mech_Shell_Fortification_MissileProjectile</defaultProjectile>
        <range>500</range>
		<warmupTime>0</warmupTime>
        <ticksBetweenBurstShots>20</ticksBetweenBurstShots>
		<forcedMissRadius>5</forcedMissRadius>
        <burstShotCount>12</burstShotCount>
        <soundCast>Shot_Autocannon</soundCast>
        <muzzleFlashScale>7</muzzleFlashScale>
		<linkedBodyPartsGroup>BulbTurret</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>false</ensureLinkedBodyPartsGroupAlwaysUsable>
		<defaultCooldownTime>5</defaultCooldownTime>
      </li>
    </verbs>
  </ThingDef>

  
  <ThingDef ParentName="NonDeconstructibleAncientBuildingBase">
		<defName>Broken_Shellcore_Bastion</defName>
		<label>Fractured Shellcore Bastion</label>
		<description>Critical structural damage detected - core systems compromised</description>
		<thingClass>NCL.Building_Ancient_WarBeacon</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
        <texPath>Buildings/BrokenShellcoreBastion</texPath>
        <graphicClass>Graphic_Single</graphicClass>
        <drawSize>(10,10)</drawSize>
        <ignoreThingDrawColor>true</ignoreThingDrawColor>
      <shadowData>
        <volume>(1.1, 0.75, 1.1)</volume>
      </shadowData>
    </graphicData>
	    <uiIconPath>Buildings/BrokenShellcoreBastion</uiIconPath>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.45</fillPercent>
		<pathCost>42</pathCost>
		<destroyable>true</destroyable>
        <useHitPoints>true</useHitPoints>
		<statBases>
		    <MaxHitPoints>20000</MaxHitPoints>
			<WorkToBuild>60000</WorkToBuild>
			<Mass>50000</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<size>(5,5)</size>
		<tickerType>Rare</tickerType>
		<rotatable>true</rotatable>
		<constructEffect>ConstructWood</constructEffect>
        <costList>
            <Steel>10000</Steel>
        </costList>
		<building>
            <alwaysDeconstructible>true</alwaysDeconstructible>
			<deconstructible>true</deconstructible>
			<destroySound>BuildingDestroyed_Wood_Small</destroySound>
		</building>
		<modExtensions>
			<li Class="NCL.ModExtension_AncientWarBeacon">
				<finalThing>TW_Complete_Shellcore_Bastion</finalThing>
				<toggleGizmoIcon>ModIcon/FixingTheBuilding</toggleGizmoIcon>
                <toggleGizmoOffIcon>ModIcon/NotFixingTheBuilding</toggleGizmoOffIcon>
				<stages>
					<li>
						<Things>
							<Steel>10000</Steel>
						</Things>
						<Rewards>
							<ComponentSpacer>1</ComponentSpacer>
						</Rewards>
						<graphic>
                           <texPath>Buildings/BrokenShellcoreBastion</texPath>
                           <graphicClass>Graphic_Single</graphicClass>
                           <drawSize>(10,10)</drawSize>
                           <shadowData>
                           <volume>(1.1, 0.75, 1.1)</volume>
                           </shadowData>
						</graphic>

					</li>
				</stages>
			</li>
		</modExtensions>
	</ThingDef>
	
