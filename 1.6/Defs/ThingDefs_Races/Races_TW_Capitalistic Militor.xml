<?xml version='1.0' encoding='utf-8'?>
<Defs>

	
  
  <ThingDef Name="TWMechCapitalisticMilitor" ParentName="LightMechanoid">
    <defName>TW_Mech_Capitalistic_Militor</defName>
    <label>Capitalist Militor</label>
    <description>This chrome-plated mechanoid merchant roams between colonies with a perpetual electronic smile, peddling what it calls "win-win Militor-Trade" - though it remains the constant winner. For sufficient steel payment, it "generously" joins your colony with assistants, ensuring you understand that "labor (especially Mecademic Militors) is the most precious renewable resource." Its core processor runs a single imperative: profit maximization.</description>
    <statBases>
      <MoveSpeed>4.3</MoveSpeed>
      <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
      <FoodPoisonChance>0</FoodPoisonChance>
	  <EMPResistance>0</EMPResistance>
      <ArmorRating_Sharp>0.5</ArmorRating_Sharp>
	  <ShootingAccuracyPawn>8</ShootingAccuracyPawn>
      <PsychicSensitivity>0</PsychicSensitivity>
      <BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">1</BandwidthCost>
      <MechEnergyLossPerHP MayRequire="Ludeon.RimWorld.Biotech">0.2</MechEnergyLossPerHP>
    </statBases>
	<comps>
	    <li Class="NCL.CompProperties_TameableMech">
            <baseTameChance>0.5</baseTameChance>
            <componentsPerTame>3</componentsPerTame>
        </li>
			<li Class="NCL.CompProperties_AllDead">
				<toggleLabelKey>NCL.FireAllUniversityStudents</toggleLabelKey>
				<toggleDescKey>NCL.FireAllUniversityStudentsDesc</toggleDescKey>
				<toggleIconPath>ModIcon/YouAreFired</toggleIconPath>
				<unableKey>NCL.CanNotFireAllUniversityStudents</unableKey>
				<mechanoidToKill>TW_University_Minitor</mechanoidToKill>
			</li>
    <li Class="NCL.CompProperties_SilverSummon">
      <silverCost>1000</silverCost>
      <pawnKinds>
        <li>TW_University_Minitor</li>
      </pawnKinds>
      <pawnCount>4</pawnCount>
      <secondaryPawnKinds>
        <li>TW_Gestapo_Minitor</li>
      </secondaryPawnKinds>
      <secondaryPawnCount>1</secondaryPawnCount>
    </li>
	</comps>
	<butcherProducts>
      <Silver>2000</Silver>
    </butcherProducts>
    <race>
        <lifeStageAges>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>0</minAge>
            <soundWounded>Pawn_Mech_Militor_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Militor_Death</soundDeath>
            <soundCall>Pawn_Mech_Militor_Call</soundCall>
          </li>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>100</minAge>
            <soundWounded>Pawn_Mech_Militor_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Militor_Death</soundDeath>
            <soundCall>Pawn_Mech_Militor_Call</soundCall>
          </li>
        </lifeStageAges>
      <baseHealthScale>4</baseHealthScale>
	  <baseBodySize>1.5</baseBodySize>
      <detritusLeavings>
        <li>
          <def>ChunkMechanoidSlag</def>
          <texOverrideIndex>11</texOverrideIndex>
          <spawnChance>0.1</spawnChance>
        </li>
      </detritusLeavings>
        <mechEnabledWorkTypes>
        </mechEnabledWorkTypes>
	<mechFixedSkillLevel>20</mechFixedSkillLevel>
    </race>
  </ThingDef>

