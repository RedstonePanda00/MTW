  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_Optical_Camo_Disruption_R</defName>
    <label>Optical Camouflage Disruption Device</label>
    <description>Random mechanoid units are equipped with optical camouflage modules, rendering them invisible. Camouflage deactivates when player units come within 45 tiles.[melee will then be 5 tiles]  Until then, the unit is invulnerable and will not attack.</description>
	<comps>
        <li Class="NCL.HediffCompProperties_InvisibilityWithEnemyAwareness">
        <detectionRadius>45</detectionRadius> 
        <checkInterval>60</checkInterval>
        <visibleToPlayer>false</visibleToPlayer>
	    </li>
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
			<RangedCooldownFactor>0.8</RangedCooldownFactor>
			<AimingDelayFactor>0.8</AimingDelayFactor>	
        </statFactors>
		<statOffsets>
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
    </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_Optical_Camo_Disruption_M</defName>
    <label>Optical Camouflage Disruption Device</label>
    <description>Random mechanoid units are equipped with optical camouflage modules, rendering them invisible on the battlefield. Camouflage deactivates when player units come within 5 tiles.</description>
	<comps>
        <li Class="NCL.HediffCompProperties_InvisibilityWithEnemyAwareness">
        <detectionRadius>5</detectionRadius> 
        <checkInterval>60</checkInterval>
        <visibleToPlayer>true</visibleToPlayer>
	    </li>
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
			<MeleeDamageFactor>1.2</MeleeDamageFactor>
        </statFactors>
		<statOffsets>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
  
  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_Overdrive_M</defName>
    <label>Mechanical Overdrive</label>
	<hediffClass>Hediff_High</hediffClass>
    <description>This mechanoid is temporarily overloaded due to massive energy infusion.</description>
    <initialSeverity>0.01</initialSeverity>
	<maxSeverity>1</maxSeverity>
	<defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
	<comps>
        <li Class="HediffCompProperties_SeverityPerDay">
            <severityPerDay>8</severityPerDay>
        </li>
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
        <label>超载</label>
		<statFactors>
            <RangedCooldownFactor>0.2</RangedCooldownFactor>
			<IncomingDamageFactor>0.4</IncomingDamageFactor>
			<AimingDelayFactor>0.2</AimingDelayFactor>
			<StaggerDurationFactor>0</StaggerDurationFactor>
        </statFactors>
		<statOffsets>
          <MoveSpeed>+4</MoveSpeed>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
		<capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>+3</offset>
            </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.20</minSeverity>
        <label>能量过剩</label>
		<statFactors>
            <RangedCooldownFactor>0.4</RangedCooldownFactor>
			<IncomingDamageFactor>0.55</IncomingDamageFactor>
			<AimingDelayFactor>0.4</AimingDelayFactor>
			<StaggerDurationFactor>0.4</StaggerDurationFactor>
        </statFactors>
		<statOffsets>
          <MoveSpeed>+2</MoveSpeed>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
		<capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>+2</offset>
            </li>
        </capMods>
      </li>    
	  <li>
		<minSeverity>0.40</minSeverity>
        <label>逐渐稳定</label>
		<statFactors>
            <RangedCooldownFactor>0.6</RangedCooldownFactor>
			<IncomingDamageFactor>0.7</IncomingDamageFactor>
			<AimingDelayFactor>0.6</AimingDelayFactor>
			<StaggerDurationFactor>0.6</StaggerDurationFactor>
        </statFactors>
		<statOffsets>
          <MoveSpeed>+1</MoveSpeed>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
		<capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>+1</offset>
            </li>
        </capMods>
      </li>
	  <li>
		<minSeverity>0.80</minSeverity>
        <label>稳定</label>
		<statFactors>
			<RangedCooldownFactor>0.8</RangedCooldownFactor>
			<IncomingDamageFactor>0.8</IncomingDamageFactor>
			<AimingDelayFactor>0.8</AimingDelayFactor>	
        </statFactors>
		<statOffsets>
          <MoveSpeed>+0.5</MoveSpeed>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>