<Defs>

    <!-- Hidden defs: only supply turretTopMat texPath via building.turretGunDef (same pipeline as vanilla Building_TurretGun). -->
    <ThingDef ParentName="ResourceBase">
        <defName>NCL_LaserDefenceTurret_TopGun</defName>
        <label>laser point defense turret top (internal)</label>
        <selectable>false</selectable>
        <useHitPoints>false</useHitPoints>
        <destroyOnDrop>true</destroyOnDrop>
        <tradeability>None</tradeability>
        <graphicData>
            <texPath>Buildings/LaserDefenseTurretItself</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(2,2)</drawSize>
            <shaderType>Cutout</shaderType>
        </graphicData>
    </ThingDef>

    <ThingDef ParentName="ResourceBase">
        <defName>TW_LaserDefenceTurret_TopGun</defName>
        <label>mech laser point defense turret top (internal)</label>
        <selectable>false</selectable>
        <useHitPoints>false</useHitPoints>
        <destroyOnDrop>true</destroyOnDrop>
        <tradeability>None</tradeability>
        <graphicData>
