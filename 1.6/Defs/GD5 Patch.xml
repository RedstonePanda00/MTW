  <HediffDef MayRequire="fxz.glitterworlddestroyer.mk5">
    <defName>Introduction_WarScorpion</defName>
    <label>Introduction: War Scorpion</label>
	<hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
    <description>Introduction: War Scorpion</description>
    <comps>
	  <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
	<stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
			<IncomingDamageFactor>0.80</IncomingDamageFactor>
        </statFactors>
		<statOffsets>
	<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
    <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
        </statOffsets>
      </li>
    </stages>
    <modExtensions>
		  <li Class="GD3.ModExtension_NotSendLetter" />
	  </modExtensions>
  </HediffDef>
  
