      <excludedDamageTypes>
        <li>Vaporize</li>
      </excludedDamageTypes>
    </li>
      <li Class="NCL.Worm.CompProperties_CauseHediff_AoEAndRing">        
        <hediff>WormPressure</hediff>
        <checkInterval>600</checkInterval>
        <range>18</range>
      </li>
      <li Class="NCL.Worm.CompProperties_DamageAbsorbedAndBoom">
