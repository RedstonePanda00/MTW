<Defs>
  
    <AbilityDef>
		<defName>NCL_Blazing_Core_Penetrator</defName>
		<label>Solaris Penetrator</label>
		<description>Propels toward target, displacing enemies along trajectory and generating large-area effect at impact zone.</description>
		<iconPath>Things/Tail</iconPath>
		<aiCanUse>false</aiCanUse>
		<cooldownTicksRange>300</cooldownTicksRange>
		<cooldownPerCharge>true</cooldownPerCharge>
		<verbProperties>
			<defaultCooldownTime>5</defaultCooldownTime>
			<verbClass>Verb_CastAbility</verbClass>
			<onlyManualCast>true</onlyManualCast>
			<range>35</range>
			<warmupTime>5</warmupTime>
			<soundCast>Shot_HellsphereCannonGun</soundCast>
		    <soundCastTail>GunTail_Heavy</soundCastTail>
			<requireLineOfSight>false</requireLineOfSight>
			<targetParams>
				<canTargetPawns>true</canTargetPawns>
				<canTargetLocations>true</canTargetLocations>
				<canTargetBuildings>true</canTargetBuildings>
			</targetParams>
			<aimingLineMote>Mote_HellsphereCannon_Aim</aimingLineMote>
            <aimingChargeMote>Mote_HellsphereCannon_Charge</aimingChargeMote>
            <aimingChargeMoteOffset>1.07</aimingChargeMoteOffset>
            <aimingLineMoteFixedLength>15.9</aimingLineMoteFixedLength>
            <aimingTargetMote>Mote_HellsphereCannon_Target</aimingTargetMote>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityLaunchProjectile">
				<projectileDef>Bullet_HellsphereCannonGun</projectileDef>
			</li>
		</comps>
	</AbilityDef>

    
