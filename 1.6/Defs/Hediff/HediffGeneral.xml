<?xml version='1.0' encoding='utf-8'?>
<Defs>
  
  <HediffDef>
    <defName>CrimsonSlagburstScorched</defName>
    <label>Crimson Slagburst Scorched</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Crimson Erosion Condensed Burn Scar</description>
    <defaultLabelColor>(128, 0, 32)</defaultLabelColor>
	<isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		  <IncomingDamageFactor>+0.25</IncomingDamageFactor>
		</statOffsets>
	    <capMods>
	      <li>
	        <capacity>Moving</capacity>
            <offset>-0.2</offset>
	      </li>
	    </capMods>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>6000~9000</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>
  
  <HediffDef>
    <defName>The_coming_death</defName>
    <label>Death Approaches</label>
	<defaultLabelColor>(220, 220, 220)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Detonate it</description>
	<isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		  <IncomingDamageFactor>+0.25</IncomingDamageFactor>
		</statOffsets>
	    <capMods>
	      <li>
	        <capacity>Moving</capacity>
            <offset>-0.2</offset>
	      </li>
	    </capMods>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120</disappearsAfterTicks>
      </li>
    <li Class="NCL.HediffCompProperties_ExplodeOnRemove">
      <damageDef>DeathExplosion</damageDef>
      <damageAmount>888</damageAmount>
      <explosionRadius>8.8</explosionRadius>
      <affectFriendly>false</affectFriendly>
    </li>
	<li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
  </HediffDef>
  
  <HediffDef>
  <defName>GD_Hediff_CloakedEffect</defName>
  <label>Optical Camouflage Active</label>
  <defaultLabelColor>(220, 220, 220)</defaultLabelColor>
  <hediffClass>HediffWithComps</hediffClass>
  <description>Optical Camouflage Active</description>
  <isBad>false</isBad>
  <comps>
    
      <li Class="HediffCompProperties_Invisibility">
        <visibleToPlayer>true</visibleToPlayer>
      </li>
    
    <li Class="HediffCompProperties_Disappears">
      <disappearsAfterTicks>3000</disappearsAfterTicks>
	  <showRemainingTime>true</showRemainingTime>
    </li>
	<li Class="HediffCompProperties_DisappearsOnDeath" />
  </comps>
</HediffDef>

  <HediffDef>
    <defName>Zero_Point_Overdrive_Hediff</defName>
    <label>Zero-Point Flash Overdrive</label>
	<defaultLabelColor>(0, 255, 255)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Mechanical joints enter overdrive mode, movement speed increased, damage taken halved, shooting cooldown halved</description>
    <isBad>false</isBad>
	<stages>
	  <li>
	    <statOffsets>
		  <IncomingDamageFactor>-0.5</IncomingDamageFactor>
		  <RangedWeapon_Cooldown>-0.5</RangedWeapon_Cooldown>
		</statOffsets>
	    <capMods>
	      <li>
	        <capacity>Moving</capacity>
            <offset>+3</offset>
	      </li>
		  <li>
            <capacity>Consciousness</capacity>
            <postFactor>+1</postFactor>
          </li>
	    </capMods>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1800</disappearsAfterTicks>
		<showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>
  
    <HediffDef>
    <defName>NCL_Shadow_Tag_Hediff</defName>
    <label>Shadow Tag</label>
	<defaultLabelColor>(220, 220, 220)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Target has been shadow tagged and cannot move for a short time</description>
    <isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		  <MoveSpeed>-999</MoveSpeed>
        </statOffsets>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1200</disappearsAfterTicks>
		<showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>


  <HediffDef>
    <defName>NCL_Terminus_Gazed_Hediff</defName>
    <label>Terminus Gaze</label>
	<defaultLabelColor>(180, 30, 30)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Final combat protocol in NCL "Moonlight Child" project, restricted to LUN-EYE-07α grade iris carriers. When activated, the implantee enters a near-divine combat state: time seems to freeze, enemies unaware, destruction arrives. But the cost is unavoidable - after protocol ends, host suffers complete neural collapse, falling into sensory paralysis and combat capability loss</description>
    <isBad>false</isBad>
	<stages>
	  <li>
	    <statFactors>
			<VEF_VerbRangeFactor>2</VEF_VerbRangeFactor>
			<RangedCooldownFactor>0.01</RangedCooldownFactor>
			<AimingDelayFactor>0.01</AimingDelayFactor>	
        </statFactors>
		<statOffsets>
		  <MoveSpeed>30</MoveSpeed>
        </statOffsets>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>10000</disappearsAfterTicks>
		<showRemainingTime>true</showRemainingTime>
      </li>
	  <li Class="HediffCompProperties_GiveAbility">
        <abilityDefs>
          <li>NCL_Phantom_Force</li>
        </abilityDefs>
      </li>
	  	<li Class="VEF.Hediffs.HediffCompProperties_Targeting">
		<neverMiss>true</neverMiss>
		<initialTargetingMoteScale>3</initialTargetingMoteScale>
		<targetingLineTexPath>UI/Overlays/ThickLine</targetingLineTexPath>
		<targetingLineColor>(255, 0, 0)</targetingLineColor>
		<targetingLineWidth>0.05</targetingLineWidth>
		</li>
		<li Class="NCL.HediffCompProperties_DisappearTrigger">
		<hediffToGive>NCL_Solar_Disruption</hediffToGive>
		</li>
    </comps>
  </HediffDef>
  
    <HediffDef>
    <defName>NCL_Overwatch_Nexus_MechBoost</defName>
    <label>Tactical Data Link Synchronization</label>
    <description>Through tactical networks built by anti-stealth radar, real-time optimization of mechanoid fire control systems significantly improves shooting accuracy and battlefield response speed</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.52, 1, 0.95)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1800</disappearsAfterTicks>
        <showRemainingTime>false</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
      <li Class="HediffCompProperties_Link">
        <requireLinkOnOtherPawn>false</requireLinkOnOtherPawn>
      </li>
    </comps>
    <stages>
      <li>
        <statFactors>
		    <ShootingAccuracyPawn>1.25</ShootingAccuracyPawn>
			<VEF_VerbRangeFactor>1.2</VEF_VerbRangeFactor>
			<AimingDelayFactor>0.8</AimingDelayFactor>	
        </statFactors>
      </li>
    </stages>
    <isBad>false</isBad>
  </HediffDef>
  
    <HediffDef>
    <defName>NCL_Solar_Disruption</defName>
    <label>Solar Decoherence</label>
	<defaultLabelColor>(180, 150, 50)</defaultLabelColor>
	<description>"Like the moon falling into the sea." Inevitable aftereffect following termination of the "Final Gaze" protocol, resulting from quantum entanglement structure rupture between photon crystal beams and neural guidance membranes, causing host's entire sensory and motor systems to enter decoherence collapse phase. Although consciousness remains, body and mind are severely dysregulated</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
	<stages>
	   <li>
	    <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.5</postFactor>
          </li>
	    </capMods>
	    <statFactors>
            <ShootingAccuracyPawn>-0.5</ShootingAccuracyPawn>
			<VEF_VerbRangeFactor>0.85</VEF_VerbRangeFactor>
			<RangedCooldownFactor>1.35</RangedCooldownFactor>
			<AimingDelayFactor>1.35</AimingDelayFactor>	
        </statFactors>
		<statOffsets>
		    <MoveSpeed>-5</MoveSpeed>
        </statOffsets>
      </li>
	</stages>
  <comps>
		<li Class="HediffCompProperties_DisappearsOnDeath" />
		<li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
		<showRemainingTime>true</showRemainingTime>
      </li>
  </comps>
  </HediffDef>
  
  <HediffDef>
    <defName>Moonlight_Synchronization</defName>
    <label>Moonlight Coherence Synchronization</label>
	<description>Stimulated by moonlight radiation, the implanted photon crystal beam iris and neural spectral guidance membrane resonate, putting the host into an overload state with significantly enhanced combat perception and reaction speed</description>
    <hediffClass>HediffWithComps</hediffClass>
	<defaultLabelColor>(0, 120, 255)</defaultLabelColor>
    <isBad>false</isBad>
	<stages>
	   <li>
	    <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>1.5</postFactor>
          </li>
	    </capMods>
	    <statFactors>
            <ShootingAccuracyPawn>72</ShootingAccuracyPawn>
			<VEF_VerbRangeFactor>1.25</VEF_VerbRangeFactor>
			<RangedCooldownFactor>0.75</RangedCooldownFactor>
			<AimingDelayFactor>0.75</AimingDelayFactor>	
        </statFactors>
		<statOffsets>
		  <PsychicSensitivity>1.5</PsychicSensitivity>
		  <MeditationFocusGain>1.5</MeditationFocusGain>
        </statOffsets>
      </li>
	</stages>
  <comps>
		<li Class="HediffCompProperties_DisappearsOnDeath" />
  </comps>
  </HediffDef>
  
    <HediffDef>
    <defName>Symbiomesh</defName>
    <label>Symbiotic Membrane: Dynamic Physiological Regulation</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Nano-fluids actively regulate physiological state, enhancing physical efficiency and operational adaptability</description>
	<defaultLabelColor>(255, 80, 80)</defaultLabelColor>
	<stages>
	  <li>
	    <statOffsets>
		  <WorkSpeedGlobal>0.1</WorkSpeedGlobal>
		  <PainShockThreshold>+0.2</PainShockThreshold>
          <ImmunityGainSpeed>+0.2</ImmunityGainSpeed>
          <InjuryHealingFactor>+0.5</InjuryHealingFactor>
		</statOffsets>
	    <statFactors>
          <StaggerDurationFactor>0.8</StaggerDurationFactor>
		  <RestFallRateFactor>0.8</RestFallRateFactor>
		  <MentalBreakThreshold>0.8</MentalBreakThreshold>
        </statFactors>
		 <hungerRateFactorOffset>-0.2</hungerRateFactorOffset>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_RemoveIfApparelDropped" />
  </comps>
    <isBad>false</isBad>
  </HediffDef>
  
    <HediffDef>
    <defName>Centurion_Arsenal_Codex_Hediff</defName>
    <label>Centurion Arsenal Codex: Composite Tactical Backmount</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>You now have everything, go for it.</description>
	<defaultLabelColor>(255, 80, 80)</defaultLabelColor>
	<stages>
	  <li>
	    <statOffsets>
		  <WorkSpeedGlobal>0.2</WorkSpeedGlobal>
		</statOffsets>
	    <statFactors>
          <JoyFallRateFactor>0.8</JoyFallRateFactor>
        </statFactors>
      </li>
	</stages>
    <comps>
      <li Class="HediffCompProperties_GiveAbility">
        <abilityDefs>
          <li>Codex_Rifle</li>
          <li>Codex_SMG</li>
          <li>Codex_Sniper</li>
          <li>Codex_M9Knife</li>
		  <li>NCL_ToggleCodexTurret</li>
        </abilityDefs>
      </li>
	  <li Class="HediffCompProperties_RemoveIfApparelDropped" />
    </comps>
    <isBad>false</isBad>
  </HediffDef>
  
  <HediffDef MayRequire="oskarpotocki.vanillafactionsexpanded.core">
    <defName>NCL_ShoulderTurretActive</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>Extended Shoulder Turret</label>
    <description>Invisible hediff with shoulder turret</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <isBad>false</isBad>
    <stages>
      <li>
        <becomeVisible>false</becomeVisible>
      </li>
    </stages>
	<comps>
		<li Class="MVCF.Comps.HediffCompProperties_ExtendedVerbGiver">
			<verbs>
				<li>
					<verbClass>Verb_Shoot</verbClass>
					<label>shoulder turret gun</label>
					<defaultProjectile>ChargedBullet_Codex_Rifle</defaultProjectile>
					<warmupTime>1.5</warmupTime>
					<range>33</range>
					<hasStandardCommand>true</hasStandardCommand>
					<ticksBetweenBurstShots>15</ticksBetweenBurstShots>
					<burstShotCount>2</burstShotCount>
					<soundCast>GunShotA</soundCast>
					<soundCastTail>GunTail_Light</soundCastTail>
					<muzzleFlashScale>9</muzzleFlashScale>
				</li>
			</verbs>
			<verbProps>
				<li>
					<label>shoulder turret gun</label>
					<visualLabel>shoulder turret gun</visualLabel>
					<description>A low caliber autonomous gun made to be mounted on a shoulder.</description>
					<canBeToggled>false</canBeToggled>
					<comps>
						<li Class="MVCF.VerbComps.VerbCompProperties_Turret">
							<compClass>MVCF.VerbComps.VerbComp_Turret</compClass>
							<humanAsDefault>true</humanAsDefault>
							<graphic>
								<texPath>Weapons/CodexTurret</texPath>
								<graphicClass>Graphic_Single</graphicClass>
								<drawSize>0.2,0.2</drawSize>
							</graphic>
							<specificPositions>
									<li>
										<defName>Human</defName>
										<BodyType>Hulk</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.4,0.45)</Up>
										<Down>(0.4,0.5)</Down>
										<Right>(-0.55,0.4)</Right>
										<Left>(0.55,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Fat</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.35,0.45)</Up>
										<Down>(0.35,0.5)</Down>
										<Right>(-0.5,0.4)</Right>
										<Left>(0.5,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Male</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.3,0.45)</Up>
										<Down>(0.3,0.4)</Down>
										<Right>(-0.4,0.4)</Right>
										<Left>(0.4,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Female</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.3,0.4)</Up>
										<Down>(0.3,0.4)</Down>
										<Right>(-0.4,0.4)</Right>
										<Left>(0.4,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Thin</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.275,0.4)</Up>
										<Down>(0.275,0.4)</Down>
										<Right>(-0.4,0.4)</Right>
										<Left>(0.4,0.4)</Left>
									</li>
								</specificPositions>
							<scalings>
								<li>
									<defName>Human</defName>
									<BodyType>Thin</BodyType>
									<scaling>0.5</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Male</BodyType>
									<scaling>0.5</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Female</BodyType>
									<scaling>0.5</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Fat</BodyType>
									<scaling>0.6</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Hulk</BodyType>
									<scaling>0.6</scaling>
								</li>
							</scalings>
						</li>
						<li Class="MVCF.VerbComps.VerbCompProperties_Cooldown">
							<compClass>MVCF.VerbComps.VerbComp_Cooldown</compClass>
							<cooldownTime>1.5</cooldownTime>
						</li>
					</comps>
				</li>
			</verbProps>
		</li>
    <li Class="HediffCompProperties_Disappears">
      <disappearsAfterTicks>30000</disappearsAfterTicks>
    </li>
	</comps>
  </HediffDef>

  <HediffDef>
    <defName>TW_WasEncouraged</defName>
    <label>Encouraged</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>Encouraged</description>
    <defaultLabelColor>(255, 80, 80)</defaultLabelColor>
	<isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		   <MoveSpeed>+1.5</MoveSpeed>
           <WorkSpeedGlobal>+1.5</WorkSpeedGlobal>
		</statOffsets>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>30000</disappearsAfterTicks>
		<showRemainingTime>true</showRemainingTime>
      </li>
	<li Class="NCL.HediffCompProperties_MechAutoRecovery">
        <tickMultiflier>600</tickMultiflier>
        <healPoint>10</healPoint>
      </li>
    </comps>
  </HediffDef>

</Defs>