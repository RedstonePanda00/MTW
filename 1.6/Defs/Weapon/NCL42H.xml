      <speed>200</speed>
    </projectile>
  </ThingDef>
  
  <ThingDef ParentName="BaseGun">
    <defName>NCL_SniperGun</defName>
    <label>NCL42H</label>
    <description>Weapon Archive: NCL42H Sniper Rifle
Designation: NCL42H  
Affiliation: Neo-Communist League "Iron Law" Standard Weapons Series  

Functional Overview:  
Specialized sniper rifle designed exclusively for Dinergate Snipers. Delivers peak performance in range, accuracy, damage, and armor penetration. Excessive weight and specialized ergonomics restrict effective operation to Dinergate units only.</description>
    <tradeability>None</tradeability>
    <destroyOnDrop>true</destroyOnDrop>
<relicChance>0</relicChance>    
    <graphicData>
      <texPath>Weapons/NCL42H</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.8</drawSize>
    </graphicData>
    <soundInteract>Interact_Rifle</soundInteract>
    <weaponClasses>
      <li>LongShots</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <statBases>
      <WorkToMake>20000</WorkToMake>
      <Mass>14.5</Mass>
      <AccuracyTouch>.7</AccuracyTouch>
      <AccuracyShort>.75</AccuracyShort>
      <AccuracyMedium>1</AccuracyMedium>
      <AccuracyLong>1</AccuracyLong>
      <RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
    </statBases>
	<smeltable>false</smeltable>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
