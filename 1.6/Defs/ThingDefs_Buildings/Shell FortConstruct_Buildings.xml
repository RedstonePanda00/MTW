<Defs>
	<ThingDef ParentName="BuildingBase">
        <defName>Building_PawnContainer</defName>
        <label>Shellcore Bastion</label>
		<thingClass>NCL.Building_PawnContainer</thingClass>
        <size>(1,1)</size>
    <building>
      <deconstructible>false</deconstructible>
      <repairable>false</repairable>
      <claimable>false</claimable>
      <expandHomeArea>false</expandHomeArea>
    </building>
        <statBases>
            <Flammability>0</Flammability>
            <MarketValue>1000</MarketValue>
            <WorkToBuild>3000</WorkToBuild>
        </statBases>
		<useHitPoints>False</useHitPoints>
        <graphicData>
            <texPath>Buildings/ShellcoreBastion</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(10,10)</drawSize>
            <ignoreThingDrawColor>true</ignoreThingDrawColor>
        </graphicData>
        <uiIconPath>Buildings/ShellcoreBastion</uiIconPath>
     <building>
      <ai_combatDangerous>true</ai_combatDangerous>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
     </building>
        <comps>
    <li Class="NCL.CompProperties_ClearOwnerProjectiles" />
            <li Class="NCL.CompProperties_ForceFaction">
                <factionDef>Mechanoid</factionDef>
            </li>
            <li Class="CompProperties_Forbiddable" />
      <li Class="TowerLaserDefense.CompProperties_LaserDefence">
                <laserDefenceProperties>
                    <range>54</range>
                    <interceptCount>4</interceptCount>
                    <interceptTime>51</interceptTime>
					<laserOffsetX>0</laserOffsetX>
					<laserOffsetY>0.7</laserOffsetY>
					<connectinglaserWidth>0.5</connectinglaserWidth>
					<ignoreAirProjectiles>false</ignoreAirProjectiles>
					<ignoreGroundProjectiles>true</ignoreGroundProjectiles>
					<connectingLineFleck>NCL_Ground_LaserDefenseLine</connectingLineFleck>
					<laserLineTexture>Motes/LaserLine</laserLineTexture>
					<impactScale>1</impactScale>
	<randomImpactFlecks>
        <li>NCL_LaserDefenseImpact_One</li>
        <li>NCL_LaserDefenseImpact_Two</li>
        <li>NCL_LaserDefenseImpact_Three</li>
        <li>NCL_LaserDefenseImpact_Four</li>
    </randomImpactFlecks>
          <secondaryImpactScale>0.5</secondaryImpactScale>
          <tertiaryImpactScale>0.5</tertiaryImpactScale>
					<interceptSound>Explosion_Rocket</interceptSound>
                    <graphicData>
                        <texPath>Things/None</texPath>
                        <graphicClass>Graphic_Single</graphicClass>
                        <drawSize>(1,1)</drawSize>
                        <shaderType>Transparent</shaderType>
                        <ignoreThingDrawColor>true</ignoreThingDrawColor>
                    </graphicData>
                    <needSight>true</needSight>
                </laserDefenceProperties>
            </li>
    <li Class="NCL.CompProperties_AloneDetonator">
        <fuseTicks>3000</fuseTicks>
        <explosiveRadius>14.5</explosiveRadius>
      <damageType>Bomb</damageType>
        <damAmount>75</damAmount>
        <checkInterval>60</checkInterval> 
        <includeDownedPawns>false</includeDownedPawns>
        <customCountdownText>自毁倒计时: {0}秒</customCountdownText>
    </li>
	<li Class="NCL.CompProperties_TurretGun_GroundTarget">
      <turretDef>Shell_FortConstruct_Barrage</turretDef> 
    </li>
		<li Class="CompProperties_Stunnable">
        <affectedDamageDefs>
          <li>Stun</li>
          <li>EMP</li>
        </affectedDamageDefs>
        </li>
        </comps>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <drawerType>MapMeshAndRealTime</drawerType>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Building</altitudeLayer>
        <stealable>false</stealable>
        <rotatable>false</rotatable>

        <placeWorkers>
            <li>TowerLaserDefense.PlaceWorker_TurretTop</li>
            <li>TowerLaserDefense.PlaceWorker_ShowTurretRadius</li>
        </placeWorkers>
    </ThingDef>
	
