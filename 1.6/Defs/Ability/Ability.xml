	<AbilityDef>
     <defName>Terminus_Gaze</defName>
     <label>Terminus Gaze</label>
     <description>This lunar bionic-derived combat protocol enables temporary omnipotent combat state: perfect accuracy, zero action delay, instant target acquisition, dark-phase teleportation, and cryonic suspension of enemies in shadows. The godlike state lasts precisely 5 hours before neural collapse renders the implantee combat-ineffective.</description>
     <iconPath>Ability/Gaze</iconPath>
	 <jobDef>CastAbilityOnThingWithoutWeapon</jobDef>
     <cooldownTicksRange>900000</cooldownTicksRange> 
     <targetRequired>false</targetRequired>
	 <showCastingProgressBar>true</showCastingProgressBar>
     <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <drawAimPie>false</drawAimPie>
      <requireLineOfSight>true</requireLineOfSight>
      <nonInterruptingSelfCast>false</nonInterruptingSelfCast>
      <warmupTime>20</warmupTime>
      <range>0</range>
      <targetable>false</targetable>
	<targetParams>
		<canTargetSelf>true</canTargetSelf>
	</targetParams>
    </verbProperties>
    <comps>
	    <li Class="NCL.CompProperties_AbilityGiveSelfHediff">
            <hediffToApply>NCL_Terminus_Gazed_Hediff</hediffToApply>
        </li>
      <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>NCL_WormBulletOnHit</effecterDef>
      </li>
	  <li Class="CompProperties_AbilityFleckOnTarget">
        <fleckDef>NCL_Fleck_Terminus_Gaze</fleckDef>
      </li>
      <li Class="NCL.CompProperties_AbilityApplyHediffInDarkness">
            <hediffToApply>NCL_Shadow_Tag_Hediff</hediffToApply> 
            <maxRange>250</maxRange>
            <darknessThreshold>0.3</darknessThreshold> 
      </li>
    </comps>
  </AbilityDef>

