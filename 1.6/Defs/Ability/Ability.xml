  	<AbilityDef>
		<defName>Zero_Point_Overdrive</defName>
		<label>Zero-Point Flash</label>
		<description>Overdrives nanomachines for instantaneous spatial translocation. Impact releases kinetic shockwave devastating nearby enemies while generating 16 unstable energy arcs. Post-translocation, user enters enhanced combat mode with significantly increased mobility, defense, and attack frequency.</description>
		<iconPath>Ability/Overdrive</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
		<verbProperties>
			<hasStandardCommand>true</hasStandardCommand>
			<verbClass>NCL.Verb_AbilityTeleport</verbClass>
			<range>-1</range>
			<requireLineOfSight>False</requireLineOfSight>
			<nonInterruptingSelfCast>False</nonInterruptingSelfCast>
			<warmupTime>0</warmupTime>			
            <ai_RangedAlawaysShootGroundBelowTarget>true</ai_RangedAlawaysShootGroundBelowTarget>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetPawns>false</canTargetPawns>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetSelf>false</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetMechs>false</canTargetMechs>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="NCL.CompProperties_AbilityCauseExplosion">
				<damageDef>Crimson_Slagburst</damageDef>
				<damageAmount>200</damageAmount>
				<explosionRadius>6.5</explosionRadius>
			</li>
			<li Class="NCL.CompProperties_ThunderStrike">
			    <lightningCount>16</lightningCount>
                <radius>3</radius>
                <damageAmount>50</damageAmount>
                <damageType>Bomb</damageType>
				<postEffectFilth>Filth_Ash</postEffectFilth>
			</li>
			<li Class="NCL.CompProperties_AbilityCasterHediff"> 
                <casterHediff>Zero_Point_Overdrive_Hediff</casterHediff>
                <ignoreIfExist>true</ignoreIfExist> 
                <initialSeverity>0.5</initialSeverity> 
            </li>
			<li Class="NCL.CompProperties_AbilityShowRange">
                 <range>282</range>
                 <minRange>0</minRange>
            </li>
			<li Class="CompProperties_AbilityEffecterOnTarget">
             <effecterDef>NCL_WormBulletOnHit</effecterDef>
            </li>
		</comps>
	</AbilityDef>
	
