    <li Class="NCL.CompProperties_ClearOwnerProjectiles">
    </li>
	  <li Class="CompProperties_Forbiddable" />
      <li Class="TowerLaserDefense.CompProperties_LaserDefence">
                <laserDefenceProperties>
                    <range>54</range>
                    <interceptCount>8</interceptCount>
                    <interceptTime>51</interceptTime>
					<laserOffsetX>0</laserOffsetX>
					<laserOffsetY>0.7</laserOffsetY>
