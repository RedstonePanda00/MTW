<?xml version='1.0' encoding='utf-8'?>
<Defs>
  
  <ThingDef ParentName="BaseMechanoid">
    <defName>TW_Mech_Birgus</defName>
    <label>Mech Birgus</label>
    <description>Tactical unit forged by the Mechanical Hive in imitation of intertidal arthropods from alien worlds. Its composite armor shell envelops precision hydraulic joints, emitting metallic clanking with each quadrupedal step. While moving at a deliberate pace rather than swift speed, its alloy appendages unleash devastating lethality at close quarters. The integrated adaptive shock-dispersal network converts impact energy into structural reinforcement - its carapace grows more durable with each impact. The abdominal compartment houses a "Microdust Mist Core" that deploys precisely targeted smoke screens upon receiving hits, weaving an agile survival barrier for itself and allied units.
  
  BUT IT IS WEAK TO FIRE.</description>
    <statBases>
      <MarketValue>6400</MarketValue>
      <MoveSpeed>4.8</MoveSpeed>
      <ArmorRating_Blunt>1.45</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.65</ArmorRating_Sharp>
      <ArmorRating_Heat>1.00</ArmorRating_Heat>
      <Flammability>0</Flammability>
      <PsychicSensitivity>0</PsychicSensitivity>
			<StaggerDurationFactor>0</StaggerDurationFactor>
	  <IncomingDamageFactor>1</IncomingDamageFactor>
	  <BandwidthCost MayRequire="Ludeon.Rimworld.Biotech">5</BandwidthCost>
	  <MechEnergyLossPerHP MayRequire="Ludeon.Rimworld.Biotech">0.2</MechEnergyLossPerHP>
	  <WastepacksPerRecharge MayRequire="Ludeon.Rimworld.Biotech">3</WastepacksPerRecharge>

    </statBases>
	<size>(1,1)</size>
<tools>
      <li>
        <label>left blade</label>
        <labelNoLocation>blade</labelNoLocation>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>50</power>
        <cooldownTime>1</cooldownTime>
        <linkedBodyPartsGroup>LeftBlade</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
      <li>
        <label>right blade</label>
        <labelNoLocation>blade</labelNoLocation>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>50</power>
        <cooldownTime>1</cooldownTime>
        <linkedBodyPartsGroup>RightBlade</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>80</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
	<damageMultipliers>
