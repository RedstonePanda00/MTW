        <defName>NCL_BrainShockResistance</defName>
        <label>brain shock resistance</label>
        <description>Chance to resist mental break side effects from EMP damage reactions.</description>
        <category>BasicsPawn</category>
        <defaultBaseValue>0</defaultBaseValue>
        <minValue>0</minValue>
        <maxValue>1</maxValue>
        <toStringStyle>PercentZero</toStringStyle>
        <showIfUndefined>false</showIfUndefined>
        <showOnPawns>false</showOnPawns>
        <displayPriorityInCategory>9990</displayPriorityInCategory>
    </StatDef>
</Defs>
