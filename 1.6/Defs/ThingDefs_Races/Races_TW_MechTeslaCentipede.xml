    <label>Tesla Centipede</label>
    <combatPower>1200</combatPower>
    <maxPerGroup>2</maxPerGroup>
    <weaponMoney>9999~9999</weaponMoney>
	<isGoodBreacher>true</isGoodBreacher>
    <weaponTags>
	<li>TW_Plasma_Arc_Projector</li>
    </weaponTags>
	<race>TW_Mech_MechTeslaCentipede</race>
    <lifeStages>
	  <li MayRequire="Ludeon.RimWorld.Biotech">
        <bodyGraphicData>
          <texPath>Races/MechTeslaCentipede</texPath>
          <maskPath>Races/MechTeslaCentipede_C</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>6</drawSize>
          <shadowData>
            <volume>(0.6, 0.8, 0.6)</volume>
          </shadowData>
        </bodyGraphicData>
      </li>
      <li>
        <bodyGraphicData>
          <texPath>Races/MechTeslaCentipedeAncient</texPath>
          <maskPath>Races/MechTeslaCentipede_C</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>6</drawSize>
          <shadowData>
            <volume>(0.4, 0.8, 0.4)</volume>
          </shadowData>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>
  
	    <FleckDef ParentName="FleckBase">
        <defName>TW_Tesla_LightnintDefenseLine</defName>
        <graphicData>
            <texPath>Motes/Tesla_Lighning</texPath>
            <shaderType>TransparentPostLight</shaderType>
            <renderInstanced>true</renderInstanced>
			<drawSize>(1, 2)</drawSize>
        </graphicData>
        <altitudeLayer>Projectile</altitudeLayer>
        <solidTime>0</solidTime>
        <fadeOutTime>0.5</fadeOutTime>
    </FleckDef>

    	    <FleckDef ParentName="FleckBase">
        <defName>NCL_SkipLine</defName>
        <graphicData>
            <texPath>Things/None</texPath>
            <shaderType>TransparentPostLight</shaderType>
            <renderInstanced>true</renderInstanced>
			<drawSize>(0, 0)</drawSize>
        </graphicData>
        <altitudeLayer>Projectile</altitudeLayer>
        <solidTime>0</solidTime>
        <fadeOutTime>0</fadeOutTime>
    </FleckDef>
  
</Defs>