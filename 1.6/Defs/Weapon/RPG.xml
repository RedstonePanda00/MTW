    <ThingDef ParentName="BaseBullet">
    <defName>TW_HE_Guided_Missile</defName>
    <label>HE-Guided Missile</label>
    <thingClass>TY_Mora_Gene_B.com.Projectile_BezierTrackingMissile</thingClass>
    <graphicData>
      <texPath>Projectiles/HE_Guided_Missile</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile>
      <damageDef>Bomb</damageDef>
	  <damageAmountBase>40</damageAmountBase>
	  <armorPenetrationBase>0.8</armorPenetrationBase>
	  <stoppingPower>1.5</stoppingPower>
      <explosionRadius>3.8</explosionRadius>
	  <flyOverhead>true</flyOverhead>
      <speed>20</speed>
    </projectile>
  <comps>
    <li Class="TY_Mora_Gene_B.com.BezierMissileProperties">
      <maxTrackingRadius>35</maxTrackingRadius>
      <maxTurnAngle>30</maxTurnAngle>
      <turnRatePerTick>1.5</turnRatePerTick>
      <canSwitchTargets>false</canSwitchTargets>
      <targetSwitchChance>1</targetSwitchChance>
      <minTargetSwitchDistance>6</minTargetSwitchDistance>
      <agilePhaseStart>0.25</agilePhaseStart>
      <agilePhaseEnd>0.85</agilePhaseEnd>
      <heightMultiplier>1.2</heightMultiplier>
      <trajectoryType>Linear</trajectoryType>
      <searchRadius>45</searchRadius>
      <trajectoryAmplitude>3</trajectoryAmplitude>
      <trajectoryFrequency>1.2</trajectoryFrequency>
      <spiralRadius>2.5</spiralRadius>
      <spiralTightness>0.6</spiralTightness>
      <tailWidth>1.4</tailWidth>
      <tailLength>3.5</tailLength>
      <smokeChance>0.8</smokeChance>
      <flecksPerBurst>4</flecksPerBurst>
      <fleckInterval>2</fleckInterval>
    </li>
    <li Class="NCL.CompProperties_FragmentedExplosive">
      <explosionRadius>5</explosionRadius>
      <fragmentCount>6</fragmentCount> 
      <guaranteedCenterFraction>0.2</guaranteedCenterFraction> 
      <fragmentProjectileDef>Bullet_NCL_Fragments</fragmentProjectileDef>
      <fireGlowSize>2.5</fireGlowSize>
    </li>
  </comps>
		<modExtensions>
			<li Class="PenetrateThickRoof.PenetrateThickRoofExtension" />
		</modExtensions>
  </ThingDef>
  
