    <ThingDef ParentName="BuildingBase">
        <defName>NCL_LaserDefenceTurret</defName>
        <thingClass>TowerLaserDefense.Building_LaserDefenceTurret</thingClass>
        <label>Laser Point Defense Turret</label>
		<description>Automated interception platform deployed on colonial frontlines. Generates high-frequency laser beams through sustained power input, effectively neutralizing slow-moving high-trajectory projectiles like mortar shells and incendiary rounds. While demonstrating high accuracy, its single-point defense capability is severely challenged against high-velocity aircraft or saturation attacks - requiring coordinated multi-turret deployment to maintain area denial coverage.</description>
        <size>(2,2)</size>
        <statBases>
            <MaxHitPoints>500</MaxHitPoints>
            <Flammability>0</Flammability>
            <MarketValue>1000</MarketValue>
            <WorkToBuild>8000</WorkToBuild>
        </statBases>
        <graphicData>
            <texPath>Buildings/LaserDefenseTurretBase</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(2,2)</drawSize>
            <ignoreThingDrawColor>true</ignoreThingDrawColor>
        </graphicData>
        <uiIconPath>Buildings/LaserDefenseTurretIcon</uiIconPath>
        <building>
            <ai_combatDangerous>true</ai_combatDangerous>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
            <turretGunDef>NCL_LaserDefenceTurret_TopGun</turretGunDef>
            <turretTopDrawSize>2</turretTopDrawSize>
        </building>
        <comps>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>150</basePowerConsumption>
            </li>
            <li Class="CompProperties_Forbiddable" />
            <li Class="TowerLaserDefense.CompProperties_LaserDefence">
                <laserDefenceProperties>
                    <range>64</range>
                    <interceptCount>1</interceptCount>
                    <interceptTime>52</interceptTime>
					<ignoreGroundProjectiles>true</ignoreGroundProjectiles>
	<randomImpactFlecks>
        <li>NCL_LaserDefenseImpact_One</li>
        <li>NCL_LaserDefenseImpact_Two</li>
        <li>NCL_LaserDefenseImpact_Three</li>
        <li>NCL_LaserDefenseImpact_Four</li>
    </randomImpactFlecks>
          <secondaryImpactScale>0.5</secondaryImpactScale>
          <tertiaryImpactScale>0.5</tertiaryImpactScale>
					<interceptSound>Explosion_Rocket</interceptSound>
					<enablePowerConsumption>true</enablePowerConsumption>
					<enableSpecialBulletExplosion>true</enableSpecialBulletExplosion>
                    <powerConsumptionPerShot>100</powerConsumptionPerShot>
                    <needSight>false</needSight>
                </laserDefenceProperties>
            </li>
		<li Class="CompProperties_Stunnable">
        <affectedDamageDefs>
          <li>Stun</li>
          <li>EMP</li>
        </affectedDamageDefs>
        </li>
        </comps>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <drawerType>MapMeshAndRealTime</drawerType>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Building</altitudeLayer>
        <stealable>false</stealable>
        <rotatable>false</rotatable>
	<researchPrerequisites>
	  <li>NCL_Helios_PD_Turret</li>
	</researchPrerequisites>
        <costList>
            <Steel>225</Steel>
            <Plasteel>75</Plasteel>
            <ComponentIndustrial>3</ComponentIndustrial>
            <ComponentSpacer>1</ComponentSpacer>
        </costList>
        <designationCategory>Security</designationCategory>
        <placeWorkers>
            <li>TowerLaserDefense.PlaceWorker_TurretTop</li>
            <li>TowerLaserDefense.PlaceWorker_ShowTurretRadius</li>
        </placeWorkers>
    </ThingDef>
	
	
	<ThingDef ParentName="BuildingBase">
        <defName>TW_LaserDefenceTurret</defName>
        <thingClass>TowerLaserDefense.Building_LaserDefenceTurret</thingClass>
        <label>Mechanoid Laser Point Defense Turret</label>
		<description>Temporary defensive installation deployed by mechanoids in forward areas. Integrated power core enables short-duration high-efficiency operation specialized in intercepting slow enemy projectiles. Upon power depletion, activates self-destruct protocol to prevent capture of core technology.</description>
        <size>(1,1)</size>
        <statBases>
            <MaxHitPoints>300</MaxHitPoints>
            <Flammability>0</Flammability>
            <MarketValue>1000</MarketValue>
            <WorkToBuild>300</WorkToBuild>
        </statBases>
        <graphicData>
            <texPath>Buildings/MechLaserDefenseTurretBase</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(2.4,2.4)</drawSize>
            <ignoreThingDrawColor>true</ignoreThingDrawColor>
        </graphicData>
        <uiIconPath>Buildings/MechLaserDefenseTurretIcon</uiIconPath>
        <building>
            <ai_combatDangerous>true</ai_combatDangerous>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
            <turretGunDef>TW_LaserDefenceTurret_TopGun</turretGunDef>
            <turretTopDrawSize>2.4</turretTopDrawSize>
        </building>
        <comps> 
            <li Class="CompProperties_Forbiddable" />
            <li Class="TowerLaserDefense.CompProperties_LaserDefence">
                <laserDefenceProperties>
                    <range>45</range>
                    <interceptCount>1</interceptCount>
                    <interceptTime>55</interceptTime>
					<ignoreGroundProjectiles>true</ignoreGroundProjectiles>
					<enableSpecialBulletExplosion>true</enableSpecialBulletExplosion>
	<randomImpactFlecks>
        <li>NCL_LaserDefenseImpact_One</li>
        <li>NCL_LaserDefenseImpact_Two</li>
        <li>NCL_LaserDefenseImpact_Three</li>
        <li>NCL_LaserDefenseImpact_Four</li>
    </randomImpactFlecks>
          <secondaryImpactScale>0.5</secondaryImpactScale>
          <tertiaryImpactScale>0.5</tertiaryImpactScale>
					<interceptSound>Explosion_Rocket</interceptSound>
                    <needSight>false</needSight>
					<requiresPower>false</requiresPower>
                </laserDefenceProperties>
            </li>
	<li Class="NCL.CompProperties_AutoExplode">
      <fuseTicks>7200</fuseTicks>
      <explosiveRadius>3.5</explosiveRadius>
      <damageType>Bomb</damageType>
      <damAmount>50</damAmount>
      <armorPenetration>0.8</armorPenetration>
    </li>
	<li Class="CompProperties_Stunnable">
        <affectedDamageDefs>
          <li>Stun</li>
          <li>EMP</li>
        </affectedDamageDefs>
    </li>
        </comps>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <drawerType>MapMeshAndRealTime</drawerType>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Building</altitudeLayer>
        <stealable>false</stealable>
        <rotatable>false</rotatable>
        <placeWorkers>
            <li>TowerLaserDefense.PlaceWorker_TurretTop</li>
            <li>TowerLaserDefense.PlaceWorker_ShowTurretRadius</li>
        </placeWorkers>
    </ThingDef>

