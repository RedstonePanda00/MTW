<?xml version='1.0' encoding='utf-8'?>
<Defs>
    <ThingDef ParentName="BuildingBase">
    <defName>NCL_Building_Lightingstrike</defName>
    <label>Tesla Beacon</label>
    <description>Strategic energy weapon system developed by the NCL League. Channels grid reserves to summon area lightning strikes against hostile units. Critical EMP discharges paralyze enemy electronics, converting power reserves into direct battlefield suppression.</description>
   <uiIconPath>Buildings/NCL_Building_Lightingstrike</uiIconPath>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <fillPercent>0.4</fillPercent>
    <altitudeLayer>Pawn</altitudeLayer>
    <graphicData>
      <texPath>Buildings/Building_Lightingstrike_Base</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(12,12)</drawSize>
      <shadowData>
        <volume>(0, 0, 0)</volume>
        <offset>(0, 0, -0.2)</offset>
      </shadowData>
    </graphicData>
    <passability>PassThroughOnly</passability>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <buildingTags>
        <li>BuildingsSecurity</li>
      </buildingTags>
    </building>
    <constructionSkillPrerequisite>5</constructionSkillPrerequisite>
    <designationCategory>Security</designationCategory>
    <uiOrder>2420</uiOrder>
    <minifiedDef>MinifiedThing</minifiedDef>
    <rotatable>false</rotatable>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>1000</MaxHitPoints>
      <WorkToBuild>8000</WorkToBuild>
      <Mass>500</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(6,6)</size>
    <costList>
      <Steel>750</Steel>
	  <Plasteel>250</Plasteel>
    <ComponentIndustrial>20</ComponentIndustrial>
	  <ComponentSpacer>8</ComponentSpacer>
    </costList>
    <researchPrerequisites>
      <li>NCL_Building_Lightingstrike</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>2000</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable" />
	<li Class="NCL.CompProperties_LightningStrike">
      <requiredPower>12000</requiredPower>
      <empRadius>25</empRadius>
      <cooldownTicks>60</cooldownTicks>
      <consumeFromBatteriesOnly>true</consumeFromBatteriesOnly>
    </li>
    <li Class="NCL.CompProperties_AutoLightningStrike">
      <empRadius>5</empRadius>
      <autoStrikeInterval>300</autoStrikeInterval>
      <autoStrikePowerCost>150</autoStrikePowerCost>
      <damageAmount>50</damageAmount>
	  <damageType>Bomb</damageType>
	  <maxTargets>3</maxTargets>
      <maxConcurrentStrikes>3</maxConcurrentStrikes>
      <enableOverdrive>true</enableOverdrive>
      <overdrivePowerMultiplier>2.0</overdrivePowerMultiplier>
      <overdriveTargetMultiplier>2</overdriveTargetMultiplier>
      <overdriveIntervalDivider>3.0</overdriveIntervalDivider>
    </li>
    <li Class="NCL.CompProperties_DualOverlay">
      
      <staticGraphicPath>Buildings/Building_Lightingstrike_BaseofTheBase</staticGraphicPath>
      <staticOffset>(-0.00, 0, 0.85)</staticOffset>
      <staticRotation>0</staticRotation>
      <staticScale>12</staticScale>
      <staticAltitudeLayer>Building</staticAltitudeLayer>
      
      
      <floatingGraphicPath>Buildings/Building_Lightingstrike_Sword</floatingGraphicPath>
      <floatingOffset>(0, -0.5, 3.8)</floatingOffset>
      <floatingRotation>0</floatingRotation>
      <floatingScale>12</floatingScale>
      <floatingAltitudeLayer>BuildingOnTop</floatingAltitudeLayer>
      
      
      <floatAmplitude>0.5</floatAmplitude>
      <floatFrequency>0.015</floatFrequency>
    </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_ShowCauseHediffAoE</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
  </ThingDef>
  
</Defs>