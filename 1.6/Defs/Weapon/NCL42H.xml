        </capacities>
        <power>9</power>
        <cooldownTime>2.1</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2.4</cooldownTime>
      </li>
